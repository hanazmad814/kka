{
  "name": "smart-product-builder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev apps/web",
    "build": "next build apps/web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "next": "14.2.23",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
